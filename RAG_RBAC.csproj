<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>RAG_RBAC</RootNamespace>
    <NoWarn>SKEXP0001;SKEXP0010</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Semantic Kernel Core (includes OpenAI connectors) -->
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.30.0" />

    <!-- Pinecone Connector -->
    <PackageReference Include="Microsoft.SemanticKernel.Connectors.Pinecone" Version="1.30.0-alpha" />

    <!-- Swagger for API testing -->
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
  </ItemGroup>

</Project>
